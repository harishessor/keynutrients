{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.5);
    padding-bottom: calc({{ section.settings.padding_bottom }}px  * 0.5);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">

    <div class="press__section">
        
        <div class="press__wrap">
            <div class="swiper_btn press--prev">
                <svg width="42" height="22" viewBox="0 0 42 22" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10.6227 2.12109L2.1215 10.6199L10.6227 19.1211" stroke="#0E1D30" stroke-width="3" stroke-miterlimit="10" stroke-linecap="square"/><path d="M3.57591 10.6196H40.0554" stroke="#0E1D30" stroke-width="3" stroke-miterlimit="10" stroke-linecap="square"/></svg>
            </div>
            <div class="press-quote h0">
                “Best value electrolytes powder”
            </div>
            <div class="swiper_btn press--next">
                <svg width="42" height="22" viewBox="0 0 42 22" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M30.9327 2.12109L39.4339 10.6199L30.9327 19.1211" stroke="#0E1D30" stroke-width="3" stroke-miterlimit="10" stroke-linecap="square"/><path d="M37.9795 10.6196H1.5" stroke="#0E1D30" stroke-width="3" stroke-miterlimit="10" stroke-linecap="square"/></svg>
            </div>
        </div>
        
        <div class="press-logos__slider swiper-container">
            <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
                {% if block.settings.image != blank %}
                <div class="press-item swiper-slide">
                    <img src="{{ block.settings.image | img_url:'master' }}" data-quote="{{ block.settings.press_quote }}" alt="Discover">
                </div>
                {% endif %} 
            {%- endfor -%}
            </div>
            <div class="swiper_buttons_mobile">
              <div class="swiper_btn press--prev">
                  <svg width="42" height="22" viewBox="0 0 42 22" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10.6227 2.12109L2.1215 10.6199L10.6227 19.1211" stroke="#0E1D30" stroke-width="3" stroke-miterlimit="10" stroke-linecap="square"/><path d="M3.57591 10.6196H40.0554" stroke="#0E1D30" stroke-width="3" stroke-miterlimit="10" stroke-linecap="square"/></svg>
              </div>

              <div class="swiper-pagination"></div>

              <div class="swiper_btn press--next">
                  <svg width="42" height="22" viewBox="0 0 42 22" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M30.9327 2.12109L39.4339 10.6199L30.9327 19.1211" stroke="#0E1D30" stroke-width="3" stroke-miterlimit="10" stroke-linecap="square"/><path d="M37.9795 10.6196H1.5" stroke="#0E1D30" stroke-width="3" stroke-miterlimit="10" stroke-linecap="square"/></svg>
              </div>
            </div>
        </div>

    </div>

  </div>
</div>

<style>
#shopify-section-{{ section.id }} .press__section .press__wrap {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6rem;
    gap: 10px;
}
#shopify-section-{{ section.id }} .press__section .press-logos__slider .press-item {
    width: 20%;
    text-align: center;
}
#shopify-section-{{ section.id }} .press__section .press-logos__slider .swiper-wrapper {
    align-items: center;
}
#shopify-section-{{ section.id }} .press__section .press-logos__slider .press-item img {
    opacity: 0.5;
    filter: contrast(0.1);
    max-width: 170px;
}
#shopify-section-{{ section.id }} .press__section .press-logos__slider .press-item.swiper-slide-active img {
    opacity: 1;
    filter: contrast(1);
}
#shopify-section-{{ section.id }} .press__section .press-quote {
  text-align: center;
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
#shopify-section-{{ section.id }} .press__section .press-quote.is-fading {
  opacity: 0;
  transform: translateY(10px); /* slide-up distance */
}
#shopify-section-{{ section.id }} .swiper_buttons_mobile {
  display: none;
}
#shopify-section-{{ section.id }} .swiper_btn {
  cursor: pointer;
}

@media(max-width: 999px){
  #shopify-section-{{ section.id }} .press__section .h0 {
    font-size: calc(var(--font-heading-scale) * 3.8rem);
  }
  #shopify-section-{{ section.id }} .press__section .press-logos__slider .press-item {
    width: 25%;
  }

}

@media(max-width: 820px){
  #shopify-section-{{ section.id }} .press__section .h0 {
    font-size: calc(var(--font-heading-scale) * 3.4rem);
  }
  #shopify-section-{{ section.id }} .press__section .press-logos__slider .press-item {
    width: 33.33%;
  }
}

@media(max-width: 749px){
  #shopify-section-{{ section.id }} .press__section .h0 {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
  }
  #shopify-section-{{ section.id }} .press__section .press__wrap .swiper_btn {
    display: none;
  }
  #shopify-section-{{ section.id }} .swiper_buttons_mobile {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 3rem;
  }
  #shopify-section-{{ section.id }} .press__section .press-quote {
    width: 100%;
  }
  #shopify-section-{{ section.id }} .swiper_buttons_mobile .swiper-pagination {
    position: relative;
    display: flex;
    align-items: center;
    gap: 15px;
  }
  #shopify-section-{{ section.id }} .swiper_buttons_mobile .swiper_btn svg {
    display: block;
    max-width: 30px;
  }
  #shopify-section-{{ section.id }} .press__section .press__wrap {
    margin-bottom: 3rem;
  }
  #shopify-section-{{ section.id }} .swiper_buttons_mobile .swiper-pagination .swiper-pagination-bullet {
    background: #C1C1C1;
    opacity: 1;
  }
  #shopify-section-{{ section.id }} .swiper_buttons_mobile .swiper-pagination .swiper-pagination-bullet-active {
    background: #6E6E6E;
  }
  #shopify-section-{{ section.id }} .press__section .press-logos__slider .press-item {
    width: 100%;
    text-align: center;
  } 
  .press-logos__slider {
    max-width: 250px;
    margin: 0 auto;
  }
}

</style>

{% schema %}
{
  "name": "Press",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "press",
      "name": "Press",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "textarea",
          "id": "press_quote",
          "label": "Quote"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press"
    }
  ]
}
{% endschema %}
