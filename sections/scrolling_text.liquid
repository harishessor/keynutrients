<script src="//cdnjs.cloudflare.com/ajax/libs/jQuery.Marquee/1.5.0/jquery.marquee.min.js" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
    <div class="section-{{ section.id }}-padding">
        <div class="marquee">
            {%- for i in (1..10) -%}
                <div class="marquee_wrap">        
                    {%- for block in section.blocks -%}
                        <div class="marquee_item">
                            {% if block.settings.icon != blank %}
                                <img class="marquee_icon" src="{{ block.settings.icon | img_url:'master' }}">
                            {% endif %}
                            {% if block.settings.text != blank %}
                                <div class="marquee_text" style="white-space: nowrap;">{{ block.settings.text }}</div>
                            {% endif %}
                        </div>                        
                    {%- endfor -%}
                </div>
            {%- endfor -%}
        </div>
    </div>
</div>



<style>
  #shopify-section-{{ section.id }} .marquee {
    display: block;
    width: 100%;
    position: relative;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .marquee_wrap,
  #shopify-section-{{ section.id }} .js-marquee {
    display: flex;
    gap: {{ section.settings.desktop_space }}px;
  }
  #shopify-section-{{ section.id }} .marquee_item {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .marquee_item .marquee_text {
    font-size: {{ section.settings.desktop_font_size }}px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    letter-spacing: 0.14px;
  }
  #shopify-section-{{ section.id }} .marquee_item .marquee_text * {
    margin:0;
  }
  #shopify-section-{{ section.id }} .marquee:not(.is-loaded) .marquee_wrap:not(:first-child) {
    display: none;
  }

  @media(max-width: 749px){
    #shopify-section-{{ section.id }} .marquee_item .marquee_text {
      font-size: {{ section.settings.mobile_font_size }}px;
    }
    #shopify-section-{{ section.id }} .marquee_wrap,
    #shopify-section-{{ section.id }} .js-marquee {
      gap: {{ section.settings.mobile_space }}px;
    }
  }
</style>



{% schema %}
{
  "name": "Scrolling Text",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Desktop Styling"
    },
    {
      "type": "range",
      "id": "desktop_font_size",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_space",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Space Between",
      "default": 40
    },
    {
      "type": "header",
      "content": "Mobile Styling"
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_space",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Space Between",
      "default": 40
    },
    {
      "type": "header",
      "content": "Color Sheme"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "t:sections.newsletter.blocks.paragraph.settings.paragraph.default",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Text",
      "blocks": [
        {
          "type": "text"
        },
        {
          "type": "text"
        },
        {
          "type": "text"
        }
      ]
    }
  ]
}
{% endschema %}
