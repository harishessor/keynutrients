{% comment %}
  FAQPage JSON-LD from product collapsible tabs (visible Q&A only). Omits script if no pairs.
{% endcomment %}
{%- liquid
  assign faq_count = 0
  for block in section.blocks
    if block.type != 'collapsible_tab'
      continue
    endif
    assign q = block.settings.heading | default: block.settings.page.title | strip
    assign a = block.settings.content | append: ' ' | append: block.settings.page.content | strip_html | strip | replace: '&nbsp;', ' ' | truncate: 8000
    if q != blank and a != blank
      assign faq_count = faq_count | plus: 1
    endif
  endfor
-%}
{%- if faq_count > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign faq_sep = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'collapsible_tab' -%}
        {%- assign q = block.settings.heading | default: block.settings.page.title | strip -%}
        {%- assign a = block.settings.content | append: ' ' | append: block.settings.page.content | strip_html | strip | replace: '&nbsp;', ' ' | truncate: 8000 -%}
        {%- if q != blank and a != blank -%}
          {%- if faq_sep -%},{%- endif -%}
          {%- assign faq_sep = true -%}
          {"@type":"Question","name":{{ q | json }},"acceptedAnswer":{"@type":"Answer","text":{{ a | json }}}}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}
