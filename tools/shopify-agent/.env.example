# Store hostname only, e.g. keynutrients.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Option A — Custom app (Admin): paste Admin API access token
SHOPIFY_ACCESS_TOKEN=

# Option B/C — Partner app: client id + secret (see README)
# B: browser OAuth (auth login) also needs redirect URL below.
# C: client credentials (auth token) — no redirect URL required.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_OAUTH_REDIRECT_URI=http://127.0.0.1:34568/callback

# Optional; default 2025-10
# SHOPIFY_API_VERSION=2025-10

# Web UI (npm run ui): host/port and max upload MB
# SHOPIFY_AGENT_UI_HOST=127.0.0.1
# SHOPIFY_AGENT_UI_PORT=3847
# SHOPIFY_AGENT_UI_MAX_MB=20
